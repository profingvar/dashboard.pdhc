FLASK_ENV=development
FLASK_APP=app:create_app
APP_PORT=9027

DB_HOST=localhost
DB_PORT=9026
DB_NAME=dashboard_pdhc_db
DB_USER=dashboard
DB_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://dashboard:changeme@localhost:9026/dashboard_pdhc_db

AUTH_MODE=off
SSO_BASE_URL=https://sso.pdhc.se
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=https://dashboard.pdhc.se/auth/callback
GATEWAY_BASE_URL=https://gateway.pdhc.se

# CDR1 (production CDR) — clinical patient picker + per-patient reads
# (#462 D2-D3 / #465). Care-delivery basis only; distinct from
# CDR_ENDPOINTS (the CDR2-6 analyse federation). Leave blank locally.
CDR1_BASE_URL=https://cdr.pdhc.se
# Outbound service key the dashboard presents to CDR1/CDR2-6
# (X-Source-Service: dashboard.pdhc). Must match the CDR side.
DASHBOARD_PDHC_SERVICE_KEY=

SECRET_KEY=replace-me
